#similating requests by taking random smaples from the data 
def create_requests(df, num_requests=150):
    request = []
    for i in range(num_requests):
        idx = np.random.randint(0, len(df))  #randomy sleceting a row from the dataframe
        row = df.iloc[idx]

        ticker = "SPX"
        date = row["Date"]
        trade_volume = int(row["Volume"])
       # trade_volume= np.random.randint(1000, 100000)

        request.append((ticker, date, trade_volume)) #request tuple 
    
    return request
 
request = create_requests(df) #creating the request dataset

#maching requests to prices 
def match_requests_to_prices(request, df):  
    requests_with_prices = []  
    
    for request in request:
        ticker = request[0]
        date = request[1]
        trade_volume = request[2]
                                                        
        dat_str = pd.to_datetime(date, format="%d %b %Y") #converting date string to match format in df
        try: 
            ref_price = df[df["Date"] == dat_str]["ref_price"].values[0] 
        except IndexError:
            closest_idx = (pd.to_datetime(df["Date"]) - pd.to_datetime(date)).abs().idxmin()
            ref_price = df.iloc[closest_idx]["ref_price"]
        
        requests_with_prices.append(([ticker, date, trade_volume], ref_price))

    return requests_with_prices
 
requests_with_prices = match_requests_to_prices(request, df) #matching the requests to prices  

#desining the QuotedTrade class (ticket that holds all info about a price quote you are givign )
class QuotedTrade:
    def __init__(self,ticker, trade_volume, ref_price, bid_price, offer_price, date):  #a class to represent a quoted trade
        self.ticker = ticker
        self.trade_volume = trade_volume
        self.ref_price = ref_price
        self.bid_price = bid_price
        self.offer_price = offer_price
        self.date = date

    def __repr__(self):
       return f"QuotedTrade(ticker={self.ticker}, trade_volume={self.trade_volume}, ref_price={self.ref_price}, bid_price={self.bid_price}, offer_price={self.offer_price}, date={self.date})"
        

#creating bid-offer spreads for each request and storing them in a list of QuotedTrade objects
def create_quoted_trades(requests_with_prices): #function that turns your trade requests into price quotes 
    """Create quoted trades with 2% spread"""
    quoted_trades = [] #create an empty list to hold the quoted trades
    
    for matched in requests_with_prices: #loop through each matched request and price 
        request_info = matched[0] #matched [0] is the request info (ticker, date, trade_volume)
        ref_price = matched[1] #matched [1] is the reference price
        ticker = request_info[0] #these 3 take apart the request info into its components
        date = request_info[1]
        trade_volume = request_info[2]

        bid_price = ref_price * 0.98 #forming 2% bid offer and offer price spread
        offer_price = ref_price * 1.02

        quoted_trade = QuotedTrade(   #created a new quotetrade object with all the information
            ticker=ticker,
            trade_volume=trade_volume,
            ref_price=ref_price,
            bid_price=bid_price,
            offer_price=offer_price,
            date=date
        )
        
        quoted_trades.append(quoted_trade) #adds this quote ticket to the list
    
    return quoted_trades  #sends back the complete list of all quote tickers 

quoted_trades = create_quoted_trades(requests_with_prices) #calls the function and stores all the quotes in a variable called quoted_trades
      

#defining a completed trade class that will hold all the information about a completed trade
class CompletedTrade:
    def __init__(self, ticker, trade_volume, trade_price, mm_action, ref_price, bid_price, offer_price, date):
        self.ticker = ticker
        self.trade_volume = trade_volume
        self.trade_price = trade_price
        self.mm_action = mm_action
        self.ref_price = ref_price
        self.bid_price = bid_price
        self.offer_price = offer_price
        self.date = date

    def __repr__(self):
        return f"CompletedTrade(ticker={self.ticker}, trade_volume={self.trade_volume}, trade_price={self.trade_price}, mm_action={self.mm_action}, ref_price={self.ref_price}, bid_price={self.bid_price}, offer_price={self.offer_price}, date={self.date})"


#now need to simulate hedge fund responses 
def simulate_hedge_fund_response(quote): 
    #can receive 3 types of responceses and we will add weights to each response 
    responses = ["buy", "sell", "refuse"]
    weights = [0.45, 0.40, 0.15]  #slight long bias for the mm

    return np.random.choice(responses, p=weights)  #randomly select a response based on the weights


#now we can process responses from the hedge fund and complete the trades 
completed_trades=[]

for quote in quoted_trades:
    hf_action = simulate_hedge_fund_response(quote) #above simulation based on quotes we provide 

    #processes undergone based on hedge fund buy or sell response 
    if hf_action == "buy": #therefore we sell to them
        mm_action = "sell"
        trade_price = quote.offer_price 
        completed_trade = CompletedTrade(
            ticker = quote.ticker,
            trade_volume = quote.trade_volume,
            trade_price=trade_price,
            mm_action=mm_action,
            ref_price=quote.ref_price,
            bid_price=quote.bid_price,
            offer_price=quote.offer_price,
            date=quote.date )
        
        completed_trades.append(completed_trade)

    elif hf_action == "sell": #therefore we buy from them
        mm_action = "buy"
        trade_price = quote.bid_price 
        completed_trade = CompletedTrade(
            ticker = quote.ticker,
            trade_volume = quote.trade_volume,
            trade_price=trade_price,
            mm_action=mm_action,
            ref_price=quote.ref_price,
            bid_price=quote.bid_price,
            offer_price=quote.offer_price,
            date=quote.date )
        
        completed_trades.append(completed_trade)

