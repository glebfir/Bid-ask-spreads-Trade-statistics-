#stacked bar chart of total pnl over time seperated by buy/sell side 
def plot_pnl_stacked_bar(completed_trades):
    """Create a stacked bar chart of PnL over time, separated by buy/sell side"""
    
    # Calculate PnL for each trade and organize by date
    pnl_data = []
    for trade in completed_trades:
        if trade.mm_action == "buy":
            pnl = trade.trade_volume * (trade.ref_price - trade.trade_price)
            side = "buy"
        else:  # mm_action == "sell"
            pnl = trade.trade_volume * (trade.trade_price - trade.ref_price)
            side = "sell"
        
        pnl_data.append({
            'date': pd.to_datetime(trade.date),
            'side': side,
            'pnl': pnl
        })
    
    # Create DataFrame and aggregate by date and side
    pnl_df = pd.DataFrame(pnl_data)
    pnl_by_date_side = pnl_df.groupby(['date', 'side'])['pnl'].sum().unstack(fill_value=0)
    pnl_by_date_side = pnl_by_date_side.sort_index()
    
    # Create stacked bar chart
    fig, ax = plt.subplots(figsize=(15, 6))
    
    pnl_by_date_side.plot(
        kind='bar',
        stacked=True,
        ax=ax,
        color=['blue', 'orange'],  # Blue for buy, orange for sell
        width=0.7
    )
    
    ax.set_xlabel('Date')
    ax.set_ylabel('P&L ($)')
    ax.set_title('P&L Over Time: Stacked by Buy/Sell Side')
    ax.legend(['Buy Side P&L', 'Sell Side P&L'], loc='upper left')
    ax.axhline(y=0, color='black', linestyle='-', linewidth=0.5)
    
    # Format y-axis as currency
    ax.yaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'${x:,.0f}'))
    
    # Show only every nth date to reduce clutter (adjust the number to show more/fewer dates)
    n = 5  # Show every 5th date
    ax.set_xticks(ax.get_xticks()[::n])
    
    # Format x-axis labels to show only date without time
    ax.set_xticklabels([date.strftime('%Y-%m-%d') for date in pnl_by_date_side.index[::n]], rotation=45, ha='right')
    
    plt.tight_layout()
    
    return pnl_by_date_side

# Generate both charts
pnl_by_date = plot_pnl_stacked_bar(completed_trades)

# Display both charts at the same time
